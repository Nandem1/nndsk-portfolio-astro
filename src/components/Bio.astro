---
import { getCollection } from "astro:content";

let sortedTimeline: Awaited<ReturnType<typeof getCollection<"timeline">>> = [];

try {
  const timeline = await getCollection("timeline");
  sortedTimeline = timeline.sort((a, b) => a.data.order - b.data.order);
} catch (error) {
  console.error("Error loading timeline:", error);
}
---

<section id="bio" class="py-24 px-6" aria-labelledby="bio-heading">
  <div class="max-w-2xl mx-auto">
    <h2
      id="bio-heading"
      class="text-3xl font-bold mb-12 text-center text-foreground"
    >
      <span class="border-b-2 border-accent/30 pb-2">Bio</span>
    </h2>

    {
      sortedTimeline.length > 0 ? (
        <ol class="space-y-8 relative">
          {sortedTimeline.map((item, index) => (
            <li class="flex gap-6 group">
              <div class="flex flex-col items-center" aria-hidden="true">
                <div class="w-3 h-3 rounded-full bg-accent group-hover:scale-125 transition-transform duration-300" />
                {index !== sortedTimeline.length - 1 && (
                  <div class="w-px h-full bg-border mt-2" />
                )}
              </div>
              <article class="pb-8 flex-1">
                <header class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-4 mb-2">
                  <time
                    class="text-sm font-mono text-accent"
                    datetime={item.data.year}
                  >
                    {item.data.year}
                  </time>
                  <h3 class="text-lg font-semibold text-foreground">
                    {item.data.title}
                  </h3>
                </header>
                <p class="text-muted leading-relaxed">
                  {item.data.description}
                </p>
              </article>
            </li>
          ))}
        </ol>
      ) : (
        <div class="text-center py-12">
          <p class="text-muted">
            No se pudo cargar la información del timeline.
          </p>
        </div>
      )
    }
  </div>
</section>
