---
export const prerender = true;

import { getCollection } from "astro:content";
import { formatDateShort } from '@/utils/date';
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";

function cleanSlug(id: string): string {
  return id.replace(/\.md$/, '');
}

let sortedPosts: Awaited<ReturnType<typeof getCollection<"blog">>> = [];

try {
  const posts = await getCollection("blog", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });

  sortedPosts = posts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );
  

} catch (error) {
  console.error("Error loading blog posts:", error);
}
---

<Layout
  title="Blog - Nande"
  description="Artículos sobre desarrollo web, tecnología y experiencias personales."
>
  <Header />
  <main class="min-h-screen py-24 px-6">
    <div class="max-w-3xl mx-auto">
      {/* Header */}
      <header class="mb-16 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-foreground mb-4">
          Blog
        </h1>
        <p class="text-muted text-lg max-w-xl mx-auto">
          Cosas que escribo cuando algo vale la pena escribirlo.
        </p>
      </header>

      {/* Lista de posts */}
      {
        sortedPosts.length > 0 ? (
          <ul class="space-y-8" role="list">
            {sortedPosts.map((post) => (
              <li>
                <article class="group">
                   <a
                     href={`/blog/${cleanSlug(post.id)}/`}
                    class="block p-6 rounded-xl bg-card border border-border hover:border-accent/50 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:ring-offset-2 focus:ring-offset-background"
                  >
                    <header class="mb-3">
                      <div class="flex items-center gap-3 text-sm text-muted font-mono mb-2">
                         <time datetime={post.data.pubDate.toISOString()}>
                           {formatDateShort(post.data.pubDate)}
                         </time>
                        {post.data.readTime && (
                          <>
                            <span aria-hidden="true">·</span>
                            <span>{post.data.readTime}</span>
                          </>
                        )}
                      </div>
                      <h2 class="text-xl font-semibold text-foreground group-hover:text-accent transition-colors">
                        {post.data.title}
                      </h2>
                    </header>

                    <p class="text-muted text-sm leading-relaxed mb-4">
                      {post.data.description}
                    </p>

                    {post.data.tags.length > 0 && (
                      <footer>
                        <ul class="flex flex-wrap gap-2" aria-label="Etiquetas">
                          {post.data.tags.map((tag) => (
                            <li>
                              <span class="px-2 py-1 text-xs rounded-full bg-background text-muted border border-border">
                                #{tag}
                              </span>
                            </li>
                          ))}
                        </ul>
                      </footer>
                    )}
                  </a>
                </article>
              </li>
            ))}
          </ul>
        ) : (
          <div class="text-center py-16">
            <p class="text-muted">No hay posts publicados aún.</p>
          </div>
        )
      }

      {/* Back link */}
      <div class="mt-16 text-center">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-muted hover:text-foreground transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m12 19-7-7 7-7"></path>
            <path d="M19 12H5"></path>
          </svg>
          Volver al inicio
        </a>
      </div>
    </div>
  </main>
</Layout>
