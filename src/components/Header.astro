---
/**
 * Componente de cabecera con navegación principal.
 * Enlaces de ancla a secciones de la home con scroll suave.
 */
import { NAV_LINKS } from '@/utils/constants';

interface NavLink {
  href: string;
  label: string;
}

const navLinks: NavLink[] = NAV_LINKS;
---

<header
  class="fixed top-0 left-0 right-0 z-50 px-6 py-4"
>
  <nav
    class="max-w-3xl mx-auto flex items-center justify-between px-6 py-3 rounded-full bg-card/80 backdrop-blur-md border border-border/50"
    aria-label="Navegación principal"
  >
    {/* Logo */}
    <a
      href="/#top"
      class="text-foreground font-bold text-lg hover:text-accent transition-colors"
      aria-label="Volver al inicio"
    >
      nndsk
    </a>

    {/* Navigation Links */}
    <ul class="flex items-center gap-4 sm:gap-6" role="list">
      {
        navLinks.map((link) => {
          const href = link.href.replace(/^\//, '');
          return (
            <li>
              <a
                href={href}
                class="text-sm font-medium transition-colors duration-300 text-muted hover:text-accent focus:outline-none focus:ring-2 focus:ring-accent/50 focus:ring-offset-2 focus:ring-offset-background rounded px-2 py-1"
              >
                {link.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>

{/* Spacer for fixed header */}
<div class="h-20" aria-hidden="true"></div>
