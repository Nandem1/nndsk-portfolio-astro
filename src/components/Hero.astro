---
/**
 * Componente hero con avatar, título, descripción y llamadas a acción.
 * Utiliza imagen optimizada de GitHub avatar con formato WebP.
 */
import { Image } from "astro:assets";
import { AVATAR_URL } from '@/utils/constants';

const avatarUrl = AVATAR_URL;
---

<section
  class="min-h-screen flex flex-col justify-center items-center px-6 py-20 relative"
  aria-labelledby="hero-title"
>
  <div class="max-w-2xl w-full text-center space-y-8">
    {/* Avatar con Image component */}
    <div class="flex justify-center" data-hero style="--hero-delay: 0ms">
      <div
        class="w-32 h-32 rounded-full overflow-hidden ring-2 ring-accent/30 ring-offset-4 ring-offset-background"
      >
        <Image
          src={avatarUrl}
          alt="Avatar del desarrollador"
          width={128}
          height={128}
          format="webp"
          quality={80}
          class="w-full h-full object-cover"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    </div>

    <div class="space-y-4" data-hero style="--hero-delay: 100ms">
      <p class="text-muted text-sm uppercase tracking-wider">
        TypeScript · Go · Rust
      </p>
      <h1
        id="hero-title"
        class="text-5xl md:text-6xl font-bold text-foreground tracking-tight"
      >
        Nande — Fullstack Developer
      </h1>
      <p class="text-xl text-accent font-medium">TypeScript • Go • Rust</p>
    </div>

    <p class="text-muted text-lg max-w-lg mx-auto leading-relaxed" data-hero style="--hero-delay: 200ms">
      Mantengo el ERP de Mercado House, soy ingeniero de
      software en EcoRetirosRM y construyo tooling en Rust. TypeScript, Rust,
      Go — en ese orden, por ahora.
    </p>

    <div class="flex justify-center gap-4 pt-4" data-hero style="--hero-delay: 300ms">
      <a
        href="#work"
        class="px-6 py-3 bg-accent/10 hover:bg-accent/20 text-accent border border-accent/30 rounded-lg transition-all duration-300 font-medium focus:outline-none focus:ring-2 focus:ring-accent/50 focus:ring-offset-2 focus:ring-offset-background"
      >
        Ver trabajos
      </a>
      <a
        href="#contact"
        class="px-6 py-3 text-muted hover:text-foreground transition-colors duration-300 font-medium focus:outline-none focus:ring-2 focus:ring-accent/50 focus:ring-offset-2 focus:ring-offset-background rounded-lg"
      >
        Contacto
      </a>
    </div>
  </div>

  {/* Scroll indicator - decorativo */}
  <div class="absolute bottom-8 animate-bounce" aria-hidden="true">
    <svg
      class="w-6 h-6 text-muted"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>
