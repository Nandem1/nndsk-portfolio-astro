---
export const prerender = true;

import { getCollection, type CollectionEntry, render } from "astro:content";
import { Image } from "astro:assets";
import { formatDateLong } from '@/utils/date';
import { AVATAR_URL } from '@/utils/constants';
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";

const avatarUrl = AVATAR_URL;

export async function getStaticPaths() {
  try {
    const posts = await getCollection("blog");
    
    function cleanSlug(id: string): string {
      return id.replace(/\.md$/, '');
    }
    
    return posts.map((post) => ({
      params: { slug: cleanSlug(post.id) },
      props: { post },
    }));
  } catch (error) {
    console.error("Error generating static paths:", error);
    return [];
  }
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);


---

<Layout title={post.data.title} description={post.data.description}>
  <Header />
  <main class="min-h-screen py-24 px-6">
    <article class="max-w-3xl mx-auto">
      {/* Header del post */}
      <header class="mb-12 text-center">
        {/* Meta info: fecha · readTime */}
        <div
          class="flex items-center justify-center gap-3 text-sm text-muted font-mono mb-4"
        >
           <time datetime={post.data.pubDate.toISOString()}>
             {formatDateLong(post.data.pubDate)}
           </time>
          {
            post.data.readTime && (
              <>
                <span aria-hidden="true">·</span>
                <span>{post.data.readTime}</span>
              </>
            )
          }
        </div>

        <h1
          class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mb-4"
        >
          {post.data.title}
        </h1>

        <p class="text-muted text-lg max-w-2xl mx-auto">
          {post.data.description}
        </p>

        {/* Author y Role con Avatar de GitHub */}
        <div class="mt-6 flex items-center justify-center gap-3">
          <div
            class="w-10 h-10 rounded-full overflow-hidden ring-2 ring-accent/30"
          >
            <Image
              src={avatarUrl}
              alt={post.data.author}
              width={40}
              height={40}
              format="webp"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="text-left">
            <div class="text-foreground font-medium">{post.data.author}</div>
            <div class="text-sm text-muted">{post.data.role}</div>
          </div>
        </div>

        {
          post.data.tags.length > 0 && (
            <div class="mt-6">
              <ul
                class="flex flex-wrap justify-center gap-2"
                aria-label="Etiquetas"
              >
                {post.data.tags.map((tag) => (
                  <li>
                    <span class="px-3 py-1 text-sm rounded-full bg-card text-muted border border-border">
                      #{tag}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </header>

      {/* Contenido */}
      <div
        class="prose prose-invert prose-zinc max-w-none
               prose-headings:text-foreground
               prose-h2:text-2xl prose-h2:font-bold prose-h2:mt-12 prose-h2:mb-4
               prose-h3:text-xl prose-h3:font-semibold prose-h3:mt-8 prose-h3:mb-3
               prose-p:text-muted prose-p:leading-relaxed
               prose-a:text-accent prose-a:no-underline hover:prose-a:underline
               prose-strong:text-foreground
               prose-code:text-accent prose-code:bg-card prose-code:px-1 prose-code:rounded
               prose-pre:bg-card prose-pre:border prose-pre:border-border
               prose-ul:text-muted prose-ol:text-muted
               prose-li:marker:text-muted
               prose-blockquote:border-accent prose-blockquote:text-muted"
      >
        <Content />
      </div>

      {/* Footer del post */}
      <footer class="mt-16 pt-8 border-t border-border">
        <div
          class="flex flex-col sm:flex-row items-center justify-between gap-4"
        >
          <div class="flex items-center gap-2 text-sm text-muted">
            <span>Escrito por</span>
            <span class="text-foreground font-medium">{post.data.author}</span>
          </div>

          <a
            href="/blog/"
            class="inline-flex items-center gap-2 text-muted hover:text-foreground transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m12 19-7-7 7-7"></path>
              <path d="M19 12H5"></path>
            </svg>
            Ver todos los posts
          </a>
        </div>
      </footer>
    </article>
  </main>
</Layout>
